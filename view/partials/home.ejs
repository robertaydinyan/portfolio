<section id="contact">
    <div class="wrap-contact">

        <form class="contact-form validate-form" action="" method="POST">
                <span class="contact-form-title">
                    Contact with me
                </span>

            <div class="wrap-input rs1-wrap-input validate-input" data-validate="Name is required">
                <span class="label-input">Your Name</span>
                <input class="input" type="text" name="name" placeholder="Enter your name">
                <span class="focus-input"></span>
            </div>

            <div class="wrap-input rs1-wrap-input validate-input" data-validate="Valid email is required: ex@abc.xyz">
                <span class="label-input">Email</span>
                <input class="input" type="text" name="email" placeholder="Enter your email addess">
                <span class="focus-input"></span>
            </div>

            <div class="wrap-input validate-input" data-validate="Message is required">
                <span class="label-input">Message</span>
                <textarea class="input" name="message" placeholder="Your message here..."></textarea>
                <span class="focus-input"></span>
            </div>


            <div class="container-contact-form-btn">
                <button name="sendMessage" class="contact-form-btn">
                        <span>
                            Submit
                            <i class="fa fa-long-arrow-right m-l-7" aria-hidden="true"></i>
                        </span>
                </button>
            </div>
        </form>

    </div>
</section>